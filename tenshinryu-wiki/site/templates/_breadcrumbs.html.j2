{% if breadcrumbs %}
<nav class="breadcrumbs" aria-label="{{ breadcrumb_label }}">
  <ol>
    {% for crumb in breadcrumbs %}
    <li>
      {% if crumb.href and not loop.last %}
      <a href="{{ crumb.href }}">{{ crumb.label }}</a>
      {% else %}
      <span{% if loop.last %} aria-current="page"{% endif %}>{{ crumb.label }}</span>
      {% endif %}
    </li>
    {% endfor %}
  </ol>
</nav>
{% endif %}
