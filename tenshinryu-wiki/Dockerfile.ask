# Wiki Ask sidecar — Gemini RAG proxy (internal; nginx → /api/ask)
FROM python:3.12-slim

WORKDIR /app

RUN pip install --no-cache-dir fastapi==0.115.6 uvicorn==0.34.0 httpx==0.28.1 pydantic==2.10.4

COPY scripts/wiki_ask.py ./wiki_ask.py

ENV WIKI_SEARCH_INDEX=/data/search-index.json
EXPOSE 8080

CMD ["uvicorn", "wiki_ask:app", "--host", "0.0.0.0", "--port", "8080"]
