# Copy via Doppler — never commit real values
NEXT_PUBLIC_APP_URL=https://dojopop.live
# Dedicated login-bot key (generate: node web/scripts/generate-login-bot-key.mjs)
DOJOPOP_LOGIN_NSEC=
DOJOPOP_LOGIN_NPUB=
DM_LOGIN_SECRET=
# CDN base for Blossom blobs (defaults to NEXT_PUBLIC_BLOSSOM_URL)
NEXT_PUBLIC_CDN_URL=https://blossom.dojopop.live
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MEMBERSHIP=
MEMBERSHIP_DATA_DIR=./data
LIGHTNING_MEMBERSHIP_SATS=10000

# Relay whitelist sync (production on relay-2)
RELAY_CONFIG_PATH=/relay/config.toml
RELAY_CONTAINER_NAME=dojopop-relay
DOCKER_SOCKET=/var/run/docker.sock
RELAY_ADMIN_PUBKEY_HEX=b3d8544ddd5896f75ef66c210f5c0d6ded9f7925163ebcbc89e678bdc1e48c6a

# Lightning membership (NWC — Alby Hub or Alby Account)
NWC_CONNECTION_SECRET=
LIGHTNING_MEMBERSHIP_SATS=10000
