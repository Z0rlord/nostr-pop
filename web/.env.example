# FILM_YOGA_SUTRA_TRAILER_URL=https://blossom.dojopop.live/example-trailer.mp4
FILM_YOGA_SUTRA_BLOSSOM_URL=
FILM_YOGA_SUTRA_BUY_SATS=100000
FILM_YOGA_SUTRA_RENT_SATS=27000
FILM_YOGA_SUTRA_BUY_STRIPE_PRICE_CENTS=1499
