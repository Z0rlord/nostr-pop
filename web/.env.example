# DojoPop web — example env (copy to .env or use Doppler)
# See README.md for full documentation.

NEXT_PUBLIC_APP_URL=https://dojopop.live
NEXT_PUBLIC_BLOSSOM_URL=https://blossom.dojopop.live
NEXT_PUBLIC_CDN_URL=https://blossom.dojopop.live

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Lightning / membership
NWC_CONNECTION_SECRET=
LIGHTNING_MEMBERSHIP_SATS=10000
MEMBERSHIP_DATA_DIR=./data

# DM login bot (generate: node web/scripts/generate-login-bot-key.mjs)
DOJOPOP_LOGIN_NSEC=
DOJOPOP_LOGIN_NPUB=
DM_LOGIN_SECRET=

# Yoga Sutra film
# Trailer: Vimeo ID (preferred) or direct MP4 URL
FILM_YOGA_SUTRA_TRAILER_VIMEO_ID=613739399
